# GitHub OAuth App credentials
# Create one at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Public URL of this app (used for OAuth callback)
BASE_URL=http://localhost:3000

# Random secret for session encryption (generate with: openssl rand -hex 32)
SESSION_SECRET=change-this-to-a-random-string

# AI model to use (gpt-4o-mini is fast and widely available)
AI_MODEL=gpt-4o-mini

# Port to listen on
PORT=3000

# Set NODE_ENV=production (or SECURE_COOKIES=1) when deploying behind HTTPS
# to enforce Secure cookies. Leave unset for local HTTP development.
# NODE_ENV=production
# SECURE_COOKIES=1
